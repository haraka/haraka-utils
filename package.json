{
  "name": "haraka-utils",
  "version": "2.1.1",
  "description": "Haraka general purpose functions",
  "main": "index.js",
  "files": [
    "CHANGELOG.md",
    "lib"
  ],
  "scripts": {
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && (git config --get core.hooksPath >/dev/null 2>&1 || git config core.hooksPath .githooks) || true",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js lib test",
    "lint:fix": "npx eslint *.js lib test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "qlty": "qlty smells --all",
    "test": "node --test",
    "test:coverage": "npx c8 --reporter=text --reporter=text-summary npm test",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haraka/haraka-utils.git"
  },
  "keywords": [
    "haraka",
    "utility",
    "utilities"
  ],
  "author": "Haraka Team <haraka.mail@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haraka/haraka-utils/issues"
  },
  "homepage": "https://github.com/haraka/haraka-utils#readme",
  "devDependencies": {
    "@haraka/eslint-config": "^3.0.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}
